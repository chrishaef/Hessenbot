# ============================================================
# Hessenbot MASTER — Umgebungsvariablen
# Kopieren nach: .env.master  (niemals ins Git einchecken!)
# ============================================================

# ── Rolle ────────────────────────────────────────────────────
HESSENBOT_ROLE=master
HESSENBOT_NODE_NAME=Hessenbot Master

# ── Cluster API (Slaves verbinden sich hierüber) ─────────────
HESSENBOT_MASTER_API_PORT=8421
HESSENBOT_API_TOKEN=HIER_SICHERES_TOKEN_EINSETZEN

# ── Master-Identität im Meshtastic-Mesh ──────────────────────
# Node-ID des Master-Radios (hex mit ! oder 0x oder dezimal)
HESSENBOT_MASTER_NODE_ID=!aabbccdd

# Master Private Key (base64) — für Key-Transfer zu Slaves.
# Exportieren aus dem Meshtastic-Radio:
#   meshtastic --export-config | grep privateKey
HESSENBOT_MASTER_PRIVATE_KEY=

# ── CouchDB (lokal, Master-Container) ────────────────────────
COUCHDB_URL=http://couchdb:5984
COUCHDB_USER=admin
COUCHDB_PASS=SICHERES_COUCH_PASSWORT
COUCHDB_BIND=127.0.0.1
HESSENBOT_MASTER_COUCH_PORT=5984

# ── MQTT ─────────────────────────────────────────────────────
# URL des MQTT-Brokers (für Slaves zur MQTT-Überwachung)
HESSENBOT_MQTT_BROKER_URL=mqtt://localhost:1883

# ── Heartbeat & Failover ─────────────────────────────────────
HESSENBOT_HEARTBEAT_INTERVAL=30
HESSENBOT_FAILOVER_THRESHOLD=3
HESSENBOT_STANDALONE_ANNOUNCE_CHANNEL=2
HESSENBOT_KEY_ANNOUNCE_INTERVAL=3600
HESSENBOT_SERVICE_CHECK_TTL=60

# ── Web-Admin ────────────────────────────────────────────────
WEB_ADMIN_BIND=127.0.0.1
WEB_ADMIN_PORT=8420
HESSENBOT_WEB_SECRET=SICHERER_FLASK_SECRET
HESSENBOT_WEB_PASSWORD=ADMIN_PASSWORT

# ── Meshtastic Hardware ──────────────────────────────────────
MESHTASTIC_SERIAL_DEVICE=/dev/ttyACM0
