# ============================================================
# Hessenbot SLAVE — Umgebungsvariablen
# Kopieren nach: .env.slave  (niemals ins Git einchecken!)
# Für jeden Standort anpassen.
# ============================================================

# ── Rolle & Identität ────────────────────────────────────────
HESSENBOT_ROLE=slave
HESSENBOT_NODE_NAME=Hessenbot FFM
# Weitere Beispiele: "Hessenbot KS", "Hessenbot DA", "Hessenbot MR"

# ── Master-Verbindung ─────────────────────────────────────────
HESSENBOT_MASTER_URL=https://master.example.com
HESSENBOT_MASTER_API_PORT=8421
HESSENBOT_MASTER_USER=slave_ffm
HESSENBOT_MASTER_PASS=SLAVE_PASSWORT
HESSENBOT_API_TOKEN=HIER_DASSELBE_TOKEN_WIE_AUF_MASTER
HESSENBOT_MASTER_COUCH_PORT=5984

# ── Master-Identität (für DM-Interception im Standalone-Modus) ─
# Node-ID des Master-Radios — gleich wie in .env.master
HESSENBOT_MASTER_NODE_ID=!aabbccdd

# Master Private Key — wird nach Autorisierung via CouchDB übertragen.
# Zunächst leer lassen; nach Key-Transfer vom Master automatisch befüllen
# oder manuell aus CouchDB hessenbot_keys abrufen.
HESSENBOT_MASTER_PRIVATE_KEY=

# ── CouchDB (lokal, Slave-Container) ─────────────────────────
COUCHDB_URL=http://couchdb:5984
COUCHDB_USER=admin
COUCHDB_PASS=SICHERES_COUCH_PASSWORT_SLAVE

# ── MQTT-Überwachung (optional — Slave prüft Broker direkt) ──
# Nur setzen wenn der Slave Sichtlinie zum MQTT-Broker hat
HESSENBOT_MQTT_BROKER_URL=
HESSENBOT_MQTT_CHECK=false

# ── Heartbeat & Failover ─────────────────────────────────────
HESSENBOT_HEARTBEAT_INTERVAL=30
HESSENBOT_FAILOVER_THRESHOLD=3
HESSENBOT_STANDALONE_ANNOUNCE_CHANNEL=2
HESSENBOT_KEY_ANNOUNCE_INTERVAL=3600
HESSENBOT_SERVICE_CHECK_TTL=60

# ── Web-Admin (lokale Verwaltung am Standort) ────────────────
WEB_ADMIN_BIND=127.0.0.1
WEB_ADMIN_PORT=8420
HESSENBOT_WEB_SECRET=SICHERER_FLASK_SECRET_SLAVE
HESSENBOT_WEB_PASSWORD=ADMIN_PASSWORT_SLAVE

# ── Meshtastic Hardware ──────────────────────────────────────
MESHTASTIC_SERIAL_DEVICE=/dev/ttyACM0
